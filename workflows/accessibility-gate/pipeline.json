{
  "id": "accessibility-gate",
  "pattern": "parallelization-aggregation",
  "description": "Run a11y and token-governance audits in parallel, aggregate, apply safe fixes with review.",
  "parallel": [
    { "id": "a11y", "skill": "penpot-audit-accessibility", "inputs": ["scope", "level:AA"], "on_fail": "report" },
    { "id": "tokens", "skill": "penpot-audit-tokens", "inputs": ["scope"], "on_fail": "report" }
  ],
  "aggregate": { "id": "merge", "after": ["a11y", "tokens"], "action": "dedupe + rank by severity" },
  "fix": { "id": "safeFix", "checkpoint": true, "policy": "safeSet only, opt-in; route rest to owning skill" },
  "output": "report: { aggregated, appliedSafeFixes, routedForReview }"
}
